generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CustomerActivityType {
  CUSTOMER_ADDED
  INVOICE_CREATED
  PAYMENT_MADE
  PACKAGE_PURCHASED
}

enum Role {
  ADMIN
  RECEPTIONIST
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum UserActivityType {
  LOGIN
  INVOICE_CREATED
  INVOICE_DELETED
  CUSTOMER_CREATED
  PASSWORD_RESET
  USER_DISABLED
  USER_ENABLED
  USER_CREATED
  USER_DELETED
}

enum StockActivityType {
  STOCK_CREATED
  STOCK_VIEWED
  BILL_VIEWED
  BILL_DOWNLOADED
  STOCK_DELETED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InvoicePaymentStatus {
  FULLY_PAID
  PARTIALLY_PAID
  PENDING
}

enum InvoicePaymentMethod {
  CASH
  CARD
  UPI
  OTHER
}

enum CatalogItemStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String          @id @default(cuid())
  username     String          @unique
  email        String?         @unique
  password     String
  name         String
  role         Role            @default(RECEPTIONIST)
  status         UserStatus      @default(ACTIVE)
  sessionVersion Int             @default(0)
  uiFontFamily String          @default("sans")
  uiFontSize   String          @default("medium")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  invoices     Invoice[]
  activities   UserActivity[]
  stockEntries StockEntry[]
  stockLogs    StockActivity[]
  expenses         Expense[]
  dailyCollections DailyCollection[]
  auditLogs        AuditLog[]
}

model UserActivity {
  id          String           @id @default(cuid())
  userId      String
  type        UserActivityType
  description String
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Customer {
  id               String         @id @default(cuid())
  name             String
  mobile           String?
  email            String?
  address          String?
  emergencyContact String?
  parentName       String?
  gstNumber        String?
  membershipId     String         @unique
  dateJoined       DateTime       @default(now())
  status           CustomerStatus @default(ACTIVE)
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  invoices         Invoice[]
  activities       CustomerActivity[]

  @@index([name])
  @@index([mobile])
  @@index([membershipId])
  @@index([deletedAt])
}

model CustomerActivity {
  id          String               @id @default(cuid())
  customerId  String
  type        CustomerActivityType
  description String
  createdAt   DateTime             @default(now())
  customer    Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
}

model Invoice {
  id               String               @id @default(cuid())
  invoiceNumber    String               @unique
  invoiceDate      DateTime             @default(now())
  dueDate          DateTime
  customerId       String?
  customerName     String
  customerMobile   String?
  customerAddress  String?
  customerGst      String?
  subtotal         Decimal              @db.Decimal(12, 2)
  cgstRate         Decimal              @default(9) @db.Decimal(5, 2)
  sgstRate         Decimal              @default(9) @db.Decimal(5, 2)
  cgstAmount       Decimal              @db.Decimal(12, 2)
  sgstAmount       Decimal              @db.Decimal(12, 2)
  totalGst         Decimal              @db.Decimal(12, 2)
  grandTotal       Decimal              @db.Decimal(12, 2)
  amountInWords    String
  paymentStatus    InvoicePaymentStatus @default(FULLY_PAID)
  paymentMethod    InvoicePaymentMethod @default(CASH)
  amountPaid       Decimal              @db.Decimal(12, 2)
  amountRemaining  Decimal              @db.Decimal(12, 2)
  gstEnabled       Boolean              @default(true)
  notes            String?
  createdById      String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
  customer         Customer?            @relation(fields: [customerId], references: [id])
  createdBy        User                 @relation(fields: [createdById], references: [id])
  items            InvoiceItem[]

  @@index([invoiceDate])
  @@index([invoiceNumber])
  @@index([paymentStatus])
  @@index([deletedAt])
}

model InvoiceItem {
  id                     String  @id @default(cuid())
  invoiceId              String
  slNo                   Int
  itemType               String
  description            String
  quantity               Int     @default(1)
  unitPrice              Decimal @db.Decimal(10, 2)
  amount                 Decimal @db.Decimal(12, 2)
  packageStartDate       DateTime?
  packageEndDate         DateTime?
  subscriptionPlanId   String?
  planNameSnapshot     String?
  descriptionSnapshot  String?
  durationSnapshot     String?
  durationValueSnapshot Int?
  durationUnitSnapshot  SubscriptionDurationUnit?
  feesSnapshot         Decimal? @db.Decimal(10, 2)
  invoice              Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  subscriptionPlan     SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
}

model InvoiceSequence {
  id         String @id @default(cuid())
  year       Int    @unique
  lastNumber Int    @default(0)
}

model Settings {
  id                 String   @id @default("default")
  academyName        String   @default("MR Academy")
  address            String   @default("")
  phonePrimary       String   @default("")
  phoneSecondary     String?
  email              String   @default("")
  website            String?
  gstNumber          String   @default("")
  gstEnabled         Boolean  @default(true)
  defaultCgstRate    Decimal  @default(0) @db.Decimal(5, 2)
  defaultSgstRate    Decimal  @default(0) @db.Decimal(5, 2)
  bankName           String?
  bankAccount        String?
  bankIfsc           String?
  bankBranch         String?
  upiId              String?
  upiQrCode          String?
  logoUrl            String   @default("/branding/logo.png")
  signatureUrl       String?
  footerImageUrl     String   @default("/branding/footer-curves.jpeg")
  headerImageUrl     String   @default("/branding/address-panel.jpeg")
  brandColor         String   @default("#0070C0")
  termsAndConditions String   @default("1. Fees once paid are non-refundable.\n2. Subject to academy rules.\n3. This is a computer generated invoice.")
  updatedAt          DateTime @updatedAt
}

enum SubscriptionDurationUnit {
  DAYS
  WEEKS
  MONTHS
  YEARS
}

model SubscriptionPlan {
  id            String                   @id @default(cuid())
  planName      String
  description   String?
  duration      String
  durationValue Int                      @default(1)
  durationUnit  SubscriptionDurationUnit @default(MONTHS)
  fees          Decimal                  @db.Decimal(10, 2)
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  invoiceItems  InvoiceItem[]

  @@index([isActive])
  @@index([planName])
}

model AcademyProduct {
  id          String             @id @default(cuid())
  name        String
  description String?
  price       Decimal            @db.Decimal(10, 2)
  status      CatalogItemStatus  @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([name])
}

model StockSequence {
  id         String @id @default(cuid())
  year       Int    @unique
  lastNumber Int    @default(0)
}

/// Physical stock purchases from suppliers. Quantity is purchase-only for now;
/// future consumption/balance tracking can add StockMovement without changing this table.
model StockEntry {
  id                String          @id @default(cuid())
  stockNumber       String          @unique
  itemName          String
  category          String
  quantityPurchased Int
  totalCost         Decimal         @db.Decimal(12, 2)
  supplierName      String
  purchaseDate      DateTime
  billPdfUrl        String?
  billFileName      String?
  remarks           String?
  createdById       String
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         User            @relation(fields: [createdById], references: [id])
  activities        StockActivity[]

  @@index([purchaseDate])
  @@index([category])
  @@index([supplierName])
  @@index([createdById])
  @@index([itemName])
  @@index([deletedAt])
}

model StockActivity {
  id           String            @id @default(cuid())
  stockEntryId String
  userId       String
  type         StockActivityType
  description  String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime          @default(now())
  stockEntry   StockEntry        @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stockEntryId])
  @@index([userId])
  @@index([createdAt])
}

model Expense {
  id          String   @id @default(cuid())
  expenseDate DateTime
  paidTo      String
  reason      String
  amount      Decimal  @db.Decimal(10, 2)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expenseDate])
}

/// End-of-day collection closing record — one row per calendar date.
model DailyCollection {
  id                  String   @id @default(cuid())
  collectionDate      DateTime @unique
  notes               String?
  collectedAt         DateTime
  collectedByUserId   String
  collectedByName     String?
  collectedBy         User     @relation(fields: [collectedByUserId], references: [id])
  totalRevenue        Decimal? @db.Decimal(12, 2)
  subscriptionRevenue Decimal? @db.Decimal(12, 2)
  productRevenue      Decimal? @db.Decimal(12, 2)
  totalExpenses       Decimal? @db.Decimal(12, 2)
  cashCollectedSystem Decimal? @db.Decimal(12, 2)
  upiCollected        Decimal? @db.Decimal(12, 2)
  netCollection       Decimal? @db.Decimal(12, 2)
  cashCountedPhysical Decimal? @db.Decimal(12, 2)
  cashDifference      Decimal? @db.Decimal(12, 2)
  cashDifferenceNotes String?
  cashDenominations   Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([collectionDate])
}

/// Central security and business audit trail (S2-01).
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  username   String?
  action     String
  entityType String?
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
