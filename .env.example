# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mra_billing?schema=public"

# Auth.js / NextAuth (required in production)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# File storage: local (default) or r2
STORAGE_DRIVER=local

# Cloudflare R2 (only when STORAGE_DRIVER=r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
