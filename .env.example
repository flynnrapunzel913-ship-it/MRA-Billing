# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mra_billing?schema=public"

# Auth.js / NextAuth (required in production on Vercel)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://mra-billing.vercel.app"
# trustHost is inferred automatically from AUTH_URL — do not set trustHost: false in code
# AUTH_TRUST_HOST=true

# Strong passwords for one-off scripts (never use defaults in production)
# SEED_ADMIN_PASSWORD=
# SEED_RECEPTION_PASSWORD=
# CLEANUP_ADMIN_PASSWORD=

# File storage: local (default) or r2
STORAGE_DRIVER=local

# Cloudflare R2 (only when STORAGE_DRIVER=r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
